# Gemini API Configuration
GEMINI_API_KEY="your-gemini-api-key"
APP_URL="your-app-url"

# Supabase Credentials
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# n8n shared secret webhook validation
N8N_SHARED_SECRET="your-n8n-shared-secret-key"

# Africa's Talking SMS API credentials
AFRICASTALKING_USERNAME="sandbox"
AFRICASTALKING_API_KEY="your-africas-talking-api-key"
AFRICASTALKING_SENDER_ID="your-shortcode-or-sender-id"

# Vercel Blob storage token for tutor certificate uploads
VERCEL_BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# LinkedIn OAuth credentials for badge mint pushes
LINKEDIN_API_KEY="your-linkedin-access-token-or-key"

# Google Calendar Integration credentials
GOOGLE_CALENDAR_CREDENTIALS_JSON='{"web":{"client_id":"...","client_secret":"..."}}'
