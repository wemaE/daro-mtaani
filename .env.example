# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase Credentials (client-side)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# n8n shared webhook validation secret
N8N_SHARED_SECRET="your-shared-secret-key"

# Vercel Blob storage token for tutor certificate uploads
VERCEL_BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# LinkedIn OAuth credential for badge mint pushes
LINKEDIN_ACCESS_TOKEN="your-linkedin-tutor-api-push-token"
